generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Game {
  LOL
  ROCKET_LEAGUE
  VALORANT
}

model Player {
  id         String   @id @default(cuid())
  nickname   String   @unique
  avatar     String?
  // Kept for backwards compatibility for now, but not actively used for game MMR. We'll transition to gameStats.
  currentMmr Int      @default(1000)
  peakMmr    Int      @default(1000)
  wins       Int      @default(0)
  losses     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  matchParticipants MatchParticipant[]
  mmrAdjustments    MmrAdjustment[]
  seasonStats       PlayerSeasonStat[]
  gameStats         PlayerGameStat[]
}

model PlayerGameStat {
  id         String   @id @default(cuid())
  playerId   String
  game       Game     @default(LOL)
  currentMmr Int      @default(1000)
  peakMmr    Int      @default(1000)
  wins       Int      @default(0)
  losses     Int      @default(0)

  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, game])
}

model Season {
  id        String   @id @default(cuid())
  name      String
  game      Game     @default(LOL)
  isActive  Boolean  @default(true)
  startDate DateTime @default(now())
  endDate   DateTime?

  matches   Match[]
  stats     PlayerSeasonStat[]
}

model PlayerSeasonStat {
  id         String   @id @default(cuid())
  playerId   String
  seasonId   String
  finalMmr   Int      @default(1000)
  peakMmr    Int      @default(1000)
  wins       Int      @default(0)
  losses     Int      @default(0)
  
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season     Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
}

model MmrAdjustment {
  id        String   @id @default(cuid())
  playerId  String
  game      Game     @default(LOL)
  amount    Int
  date      DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Match {
  id        String   @id @default(cuid())
  game      Game     @default(LOL)
  date      DateTime @default(now())
  winner    String   // "BLUE" or "RED"
  seasonId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MatchParticipant[]
  season       Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
}

model MatchParticipant {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     String // "BLUE" or "RED"
  champion String
  kills    Int
  deaths   Int
  assists  Int
  points   Int?   @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
}
